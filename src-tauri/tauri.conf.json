{
  "$schema": "https://raw.githubusercontent.com/nicedouble/tauri-schema/main/tauri.conf.schema.json",
  "productName": "GS Report Analytics",
  "version": "1.0.0",
  "identifier": "com.gs-analytics.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "GS Report Analytics",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
